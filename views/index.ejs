<%- include('partials/header') %>

<div class="hero">
  <h1><i class="fas fa-users"></i> Student Management System</h1>
  <p class="lead">Manage your students easily with our modern platform</p>
  <a href="/add" class="btn btn-light btn-lg"><i class="fas fa-plus-circle"></i> Add New Student</a>
</div>

<div class="card">
  <div class="card-body">
    <h2 class="card-title mb-4"><i class="fas fa-list"></i> All Students</h2>
    <% if (students.length === 0) { %>
      <div class="alert alert-info">No students found. <a href="/add">Add one</a>.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            
              <th><i class="fas fa-user"></i> Name</th>
              <th><i class="fas fa-calendar-alt"></i> Age</th>
              <th><i class="fas fa-envelope"></i> Email</th>
              <th><i class="fas fa-book"></i> Course</th>
              <th><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(student => { %>
              <tr>
                <td><%= student.name %></td>
                <td><%= student.age %></td>
                <td><%= student.email %></td>
                <td><%= student.course %></td>
                <td>
                  <div class="d-flex flex-wrap gap-2">
                    <a href="/<%= student._id %>" class="btn btn-sm btn-info"><i class="fas fa-eye"></i> View</a>
                    <a href="/<%= student._id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Edit</a>
                    <form action="/<%= student._id %>?_method=DELETE" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')"><i class="fas fa-trash"></i> Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>